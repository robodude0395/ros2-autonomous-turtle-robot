<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="turtlebot">

  <!-- ======================== PARAMETERS ======================== -->
  <!-- TODO: Measure and fill in your actual values -->

  <!-- Base plate (MDF circle) -->
  <xacro:property name="base_radius" value="0.195"/>       <!-- metres -->
  <xacro:property name="base_height" value="0.006"/>      <!-- MDF thickness -->
  <xacro:property name="base_separation" value="0.171"/>   <!-- vertical gap between the two plates -->

  <!-- Wheels -->
  <xacro:property name="wheel_radius" value="0.05"/>
  <xacro:property name="wheel_width" value="0.025"/>
  <xacro:property name="wheel_separation" value="0.38"/> <!-- centre-to-centre, match firmware -->
  <xacro:property name="wheel_z_offset" value="0.020"/>     <!-- wheel centre height relative to base_link -->

  <!-- Caster (passive support) -->
  <xacro:property name="caster_radius" value="0.015"/>

  <!-- Kinect sensor -->
  <xacro:property name="kinect_x_offset" value="0.176"/>    <!-- forward from base centre -->
  <xacro:property name="kinect_z_offset" value="0.0"/>    <!-- height above top plate -->

  <!-- ======================== MATERIALS ======================== -->
  <material name="wood">
    <color rgba="0.76 0.60 0.42 1.0"/>
  </material>
  <material name="black">
    <color rgba="0.1 0.1 0.1 1.0"/>
  </material>
  <material name="dark_grey">
    <color rgba="0.3 0.3 0.3 1.0"/>
  </material>

  <!-- ======================== BASE LINK ======================== -->
  <!-- base_link sits at the centre of the robot at ground level -->
  <link name="base_link"/>

  <!-- base_footprint is on the ground plane (for Nav2) -->
  <link name="base_footprint"/>
  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_link"/>
    <child link="base_footprint"/>
    <origin xyz="0 0 ${-(wheel_radius)}" rpy="0 0 0"/>
  </joint>

  <!-- ======================== BOTTOM PLATE ======================== -->
  <link name="bottom_plate">
    <visual>
      <geometry>
        <cylinder radius="${base_radius}" length="${base_height}"/>
      </geometry>
      <material name="wood"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="${base_radius}" length="${base_height}"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.002"/>
    </inertial>
  </link>
  <joint name="bottom_plate_joint" type="fixed">
    <parent link="base_link"/>
    <child link="bottom_plate"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- ======================== TOP PLATE ======================== -->
  <link name="top_plate">
    <visual>
      <geometry>
        <cylinder radius="${base_radius}" length="${base_height}"/>
      </geometry>
      <material name="wood"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="${base_radius}" length="${base_height}"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.002"/>
    </inertial>
  </link>
  <joint name="top_plate_joint" type="fixed">
    <parent link="base_link"/>
    <child link="top_plate"/>
    <origin xyz="0 0 ${base_separation}" rpy="0 0 0"/>
  </joint>

  <!-- ======================== WHEEL MACRO ======================== -->
  <xacro:macro name="wheel" params="prefix y_reflect">
    <link name="${prefix}_wheel">
      <visual>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <material name="black"/>
      </visual>
      <collision>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
      </collision>
      <inertial>
        <mass value="0.2"/>
        <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
      </inertial>
    </link>
    <joint name="${prefix}_wheel_joint" type="continuous">
      <parent link="base_link"/>
      <child link="${prefix}_wheel"/>
      <origin xyz="0 ${y_reflect * wheel_separation / 2} ${wheel_z_offset}" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
    </joint>
  </xacro:macro>

  <xacro:wheel prefix="left" y_reflect="1"/>
  <xacro:wheel prefix="right" y_reflect="-1"/>

  <!-- ======================== CASTER ======================== -->
  <link name="caster">
    <visual>
      <geometry>
        <sphere radius="${caster_radius}"/>
      </geometry>
      <material name="dark_grey"/>
    </visual>
    <collision>
      <geometry>
        <sphere radius="${caster_radius}"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.00001" ixy="0" ixz="0" iyy="0.00001" iyz="0" izz="0.00001"/>
    </inertial>
  </link>
  <joint name="caster_joint" type="fixed">
    <parent link="base_link"/>
    <child link="caster"/>
    <origin xyz="${-base_radius + caster_radius + 0.01} 0 ${-(wheel_radius - caster_radius)}" rpy="0 0 0"/>
  </joint>

  <!-- ======================== KINECT ======================== -->
  <link name="kinect_link">
    <visual>
      <geometry>
        <box size="0.07 0.28 0.07"/>
      </geometry>
      <material name="dark_grey"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.07 0.28 0.07"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.3"/>
      <inertia ixx="0.0002" ixy="0" ixz="0" iyy="0.0002" iyz="0" izz="0.0001"/>
    </inertial>
  </link>
  <joint name="kinect_joint" type="fixed">
    <parent link="top_plate"/>
    <child link="kinect_link"/>
    <origin xyz="${kinect_x_offset} 0 ${base_height/2 + 0.035 + kinect_z_offset}" rpy="0 0 0"/>
  </joint>

  <!-- Kinect optical frame (Z forward, X right, Y down — standard camera convention) -->
  <link name="kinect_depth_frame"/>
  <joint name="kinect_depth_joint" type="fixed">
    <parent link="kinect_link"/>
    <child link="kinect_depth_frame"/>
    <origin xyz="0 0 0" rpy="${-pi/2} 0 ${-pi/2}"/>
  </joint>

  <!-- Alias for the frame_id published by the Kinect driver / depthimage_to_laserscan -->
  <link name="camera_depth_frame"/>
  <joint name="camera_depth_frame_joint" type="fixed">
    <parent link="kinect_link"/>
    <child link="camera_depth_frame"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

</robot>
